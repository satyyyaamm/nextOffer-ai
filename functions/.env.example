# Optional — server-side GA4 purchase events (see ANALYTICS.md)
# For production:
#   cp functions/.env.example functions/.env.YOUR_PROJECT_ID

GA4_MEASUREMENT_ID=

# Optional — multi-source job search (see SETUP.md)
# JSearch (RAPIDAPI_KEY) is required via Firebase Secrets.
# Jooble + Adzuna extend coverage when configured:
JOOBLE_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Admin dashboard — comma-separated emails allowed to sign in at /admin
ADMIN_EMAILS=you@example.com
ADMIN_PASSWORD=your-secure-password
