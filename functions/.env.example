# Backend environment (local emulator only)
# For production, set FRONTEND_URL via Firebase:
#   echo "FRONTEND_URL=https://your-project.web.app" > functions/.env.YOUR_PROJECT_ID
#
FRONTEND_URL=http://localhost:3000

# Optional: GA4 Measurement Protocol for server-side purchase_success (webhook)
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Set GA4_API_SECRET via: firebase functions:secrets:set GA4_API_SECRET
