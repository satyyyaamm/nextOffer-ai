# ─────────────────────────────────────────────────────────────
# JobCraft AI — Frontend Environment Variables
# Copy to .env.local and fill in your values.
# NEVER put secret keys here — they belong in Firebase Secrets.
# ─────────────────────────────────────────────────────────────

# Firebase (Project Settings → General → Your apps → Web app)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
# Required for production analytics (Firebase → Project settings → Web app)
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Set to true locally to validate events in Firebase DebugView
# REACT_APP_ANALYTICS_DEBUG=true

# Payments: Razorpay runs on the backend only (see PAYMENTS.md).
# No payment keys needed in the frontend.
